{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "RDS PostgreSQL instance with Secrets Manager managed credentials for RAG pipeline",
    "Parameters": {
        "InternalSecurityGroupId": {
            "Type": "AWS::EC2::SecurityGroup::Id",
            "Description": "Pre-provisioned internal security group ID provided by IT"
        },
        "DeletionProtection": {
            "Type": "String",
            "Default": "false",
            "AllowedValues": [
                "true",
                "false"
            ],
            "Description": "Enable deletion protection. Set to true for production to prevent accidental deletion."
        },
        "DeploymentDate": {
            "Type": "String",
            "AllowedPattern": "^\\d{2}-\\d{2}-\\d{4}$",
            "Description": "Deployment date in MM-DD-YYYY format (e.g. 07-15-2026). Used in the DB instance identifier."
        },
        "KmsKeyArn": {
            "Type": "String",
            "Default": "",
            "Description": "Optional KMS key ARN for storage and Secrets Manager encryption. Leave empty to use the AWS-managed default key. IT should supply a CMK ARN for production/compliance environments."
        },
        "MasterUsername": {
            "Type": "String",
            "Default": "pgadmin",
            "Description": "Master username for the PostgreSQL instance",
            "NoEcho": true
        },
        "MultiAZ": {
            "Type": "String",
            "Default": "false",
            "AllowedValues": [
                "true",
                "false"
            ],
            "Description": "Enable Multi-AZ deployment for high availability. Set to true for production workloads that require automatic failover and enhanced durability. Leave false for dev/test or cost-sensitive prototypes."
        },
        "PrivateSubnetIds": {
            "Type": "List<AWS::EC2::Subnet::Id>",
            "Description": "At least two private subnet IDs in different AZs for the DB subnet group"
        },
        "ProjectPrefix": {
            "Type": "String",
            "MaxLength": 30,
            "AllowedPattern": "^[a-z0-9][a-z0-9\\-]*[a-z0-9]$",
            "Description": "Short prefix for resource names (e.g. rag-dev). Max 30 chars, lowercase alphanumeric and hyphens only."
        },
        "VpcId": {
            "Type": "AWS::EC2::VPC::Id",
            "Description": "VPC ID where the RDS instance will be deployed"
        },
        "EnvironmentTag": {
            "Type": "String",
            "Description": "Environment tag value for resources (e.g. Production, Staging, Development)"
        }
    },
    "Conditions": {
        "HasCustomKmsKey": {
            "Fn::Not": [
                {
                    "Fn::Equals": [
                        {
                            "Ref": "KmsKeyArn"
                        },
                        ""
                    ]
                }
            ]
        }
    },
    "Resources": {
        "DBSubnetGroup": {
            "Type": "AWS::RDS::DBSubnetGroup",
            "Properties": {
                "DBSubnetGroupDescription": {
                    "Fn::Sub": "${ProjectPrefix} RDS subnet group"
                },
                "SubnetIds": {
                    "Ref": "PrivateSubnetIds"
                },
                "Tags": [
                    {
                        "Key": "Environment",
                        "Value": { "Ref": "EnvironmentTag" }
                    },
                    {
                        "Key": "Project",
                        "Value": "RAGPipeline"
                    }
                ]
            }
        },
        "PostgresInstance": {
            "Type": "AWS::RDS::DBInstance",
            "DeletionPolicy": "Snapshot",
            "UpdateReplacePolicy": "Snapshot",
            "Properties": {
                "DBInstanceIdentifier": {
                    "Fn::Sub": "${ProjectPrefix}-pg-${DeploymentDate}"
                },
                "DBName": {
                    "Fn::Join": [
                        "",
                        {
                            "Fn::Split": [
                                "-",
                                {
                                    "Ref": "ProjectPrefix"
                                }
                            ]
                        }
                    ]
                },
                "Engine": "postgres",
                "EngineVersion": "16.8",
                "DBInstanceClass": "db.t4g.small",
                "AllocatedStorage": 20,
                "StorageType": "gp3",
                "StorageEncrypted": true,
                "KmsKeyId": {
                    "Fn::If": [
                        "HasCustomKmsKey",
                        {
                            "Ref": "KmsKeyArn"
                        },
                        {
                            "Ref": "AWS::NoValue"
                        }
                    ]
                },
                "MasterUsername": {
                    "Ref": "MasterUsername"
                },
                "ManageMasterUserPassword": true,
                "MasterUserSecret": {
                    "Fn::If": [
                        "HasCustomKmsKey",
                        {
                            "KmsKeyId": {
                                "Ref": "KmsKeyArn"
                            }
                        },
                        {
                            "Ref": "AWS::NoValue"
                        }
                    ]
                },
                "DBSubnetGroupName": {
                    "Ref": "DBSubnetGroup"
                },
                "VPCSecurityGroups": [
                    {
                        "Ref": "InternalSecurityGroupId"
                    }
                ],
                "MultiAZ": {
                    "Ref": "MultiAZ"
                },
                "PubliclyAccessible": false,
                "BackupRetentionPeriod": 7,
                "DeletionProtection": {
                    "Ref": "DeletionProtection"
                },
                "MonitoringInterval": 60,
                "MonitoringRoleArn": {
                    "Fn::GetAtt": [
                        "RDSEnhancedMonitoringRole",
                        "Arn"
                    ]
                },
                "EnableCloudwatchLogsExports": [
                    "postgresql",
                    "upgrade"
                ],
                "AutoMinorVersionUpgrade": true,
                "CopyTagsToSnapshot": true,
                "Tags": [
                    {
                        "Key": "Environment",
                        "Value": { "Ref": "EnvironmentTag" }
                    },
                    {
                        "Key": "Project",
                        "Value": "RAGPipeline"
                    }
                ]
            }
        },
        "RDSEnhancedMonitoringRole": {
            "Type": "AWS::IAM::Role",
            "Properties": {
                "RoleName": {
                    "Fn::Sub": "${ProjectPrefix}-rds-monitoring-role"
                },
                "AssumeRolePolicyDocument": {
                    "Version": "2012-10-17",
                    "Statement": [
                        {
                            "Effect": "Allow",
                            "Principal": {
                                "Service": "monitoring.rds.amazonaws.com"
                            },
                            "Action": "sts:AssumeRole"
                        }
                    ]
                },
                "ManagedPolicyArns": [
                    {
                        "Fn::Sub": "arn:${AWS::Partition}:iam::aws:policy/service-role/AmazonRDSEnhancedMonitoringRole"
                    }
                ],
                "Tags": [
                    {
                        "Key": "Environment",
                        "Value": { "Ref": "EnvironmentTag" }
                    },
                    {
                        "Key": "Project",
                        "Value": "RAGPipeline"
                    }
                ]
            }
        }

    },
    "Outputs": {
        "DBInstanceArn": {
            "Description": "ARN of the RDS instance",
            "Value": {
                "Fn::Sub": "arn:${AWS::Partition}:rds:${AWS::Region}:${AWS::AccountId}:db:${PostgresInstance}"
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-DBInstanceArn"
                }
            }
        },
        "DBInstanceEndpoint": {
            "Description": "RDS instance endpoint address",
            "Value": {
                "Fn::GetAtt": [
                    "PostgresInstance",
                    "Endpoint.Address"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-DBInstanceEndpoint"
                }
            }
        },
        "DBInstancePort": {
            "Description": "RDS instance port",
            "Value": {
                "Fn::GetAtt": [
                    "PostgresInstance",
                    "Endpoint.Port"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-DBInstancePort"
                }
            }
        },
        "DBName": {
            "Description": "Name of the initial database",
            "Value": {
                "Fn::Join": [
                    "",
                    {
                        "Fn::Split": [
                            "-",
                            {
                                "Ref": "ProjectPrefix"
                            }
                        ]
                    }
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-DBName"
                }
            }
        },
        "MasterUserSecretArn": {
            "Description": "ARN of the Secrets Manager secret containing master credentials. Use this to retrieve connection info in your application.",
            "Value": {
                "Fn::GetAtt": [
                    "PostgresInstance",
                    "MasterUserSecret.SecretArn"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-MasterUserSecretArn"
                }
            }
        },
        "RDSSecurityGroupId": {
            "Description": "Security group ID used by the RDS instance (internal SG from parent stack)",
            "Value": {
                "Ref": "InternalSecurityGroupId"
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-RDSSecurityGroupId"
                }
            }
        }
    }
}
