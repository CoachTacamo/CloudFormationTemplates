{
    "AWSTemplateFormatVersion": "2010-09-09",
    "Description": "OpenSearch Serverless vector search collection for RAG pipeline",
    "Parameters": {
        "InternalSecurityGroupId": {
            "Type": "AWS::EC2::SecurityGroup::Id",
            "Description": "Pre-provisioned internal security group ID provided by IT"
        },
        "PrivateSubnetAId": {
            "Type": "AWS::EC2::Subnet::Id",
            "Description": "Private Subnet A ID for the OpenSearch VPC endpoint"
        },
        "PrivateSubnetBId": {
            "Type": "AWS::EC2::Subnet::Id",
            "Description": "Private Subnet B ID for the OpenSearch VPC endpoint"
        },
        "ProjectPrefix": {
            "Type": "String",
            "MaxLength": 24,
            "AllowedPattern": "^[a-z][a-z0-9\\-]*[a-z0-9]$",
            "Description": "Project prefix used to derive the collection name (e.g. rag-dev \u2192 rag-dev-vectors)"
        },
        "StandbyReplicas": {
            "Type": "String",
            "Default": "DISABLED",
            "AllowedValues": [
                "ENABLED",
                "DISABLED"
            ],
            "Description": "Enable standby replicas for HA (DISABLED cuts cost in half for dev/test)"
        },
        "VpcId": {
            "Type": "AWS::EC2::VPC::Id",
            "Description": "VPC ID where the OpenSearch VPC endpoint will be created"
        },
        "EnvironmentTag": {
            "Type": "String",
            "Description": "Environment tag value for resources (e.g. Production, Staging, Development)"
        }
    },
    "Resources": {
        "DataAccessPolicy": {
            "Type": "AWS::OpenSearchServerless::AccessPolicy",
            "Properties": {
                "Name": {
                    "Fn::Sub": "${ProjectPrefix}-vectors-access"
                },
                "Type": "data",
                "Description": "Data access policy for RAG pipeline roles",
                "Policy": {
                    "Fn::Sub": "[{\"Description\":\"Pipeline access\",\"Rules\":[{\"ResourceType\":\"index\",\"Resource\":[\"index/${ProjectPrefix}-vectors/*\"],\"Permission\":[\"aoss:CreateIndex\",\"aoss:DeleteIndex\",\"aoss:UpdateIndex\",\"aoss:DescribeIndex\",\"aoss:ReadDocument\",\"aoss:WriteDocument\"]},{\"ResourceType\":\"collection\",\"Resource\":[\"collection/${ProjectPrefix}-vectors\"],\"Permission\":[\"aoss:CreateCollectionItems\",\"aoss:DescribeCollectionItems\",\"aoss:UpdateCollectionItems\"]}],\"Principal\":[\"arn:aws:iam::${AWS::AccountId}:root\"]}]"
                }
            }
        },
        "EncryptionPolicy": {
            "Type": "AWS::OpenSearchServerless::SecurityPolicy",
            "Properties": {
                "Name": {
                    "Fn::Sub": "${ProjectPrefix}-vectors-enc"
                },
                "Type": "encryption",
                "Description": "Encryption policy for RAG vector collection",
                "Policy": {
                    "Fn::Sub": "{\"Rules\":[{\"ResourceType\":\"collection\",\"Resource\":[\"collection/${ProjectPrefix}-vectors\"]}],\"AWSOwnedKey\":true}"
                }
            }
        },
        "NetworkPolicy": {
            "Type": "AWS::OpenSearchServerless::SecurityPolicy",
            "Properties": {
                "Name": {
                    "Fn::Sub": "${ProjectPrefix}-vectors-net"
                },
                "Type": "network",
                "Description": "Network policy for RAG vector collection \u2014 VPC-only access, no public",
                "Policy": {
                    "Fn::Sub": [
                        "[{\"Rules\":[{\"ResourceType\":\"collection\",\"Resource\":[\"collection/${ProjectPrefix}-vectors\"]},{\"ResourceType\":\"dashboard\",\"Resource\":[\"collection/${ProjectPrefix}-vectors\"]}],\"AllowFromPublic\":false,\"SourceVPCEs\":[\"${VpceId}\"]}]",
                        {
                            "VpceId": {
                                "Fn::GetAtt": [
                                    "OpenSearchVpcEndpoint",
                                    "Id"
                                ]
                            }
                        }
                    ]
                }
            }
        },
        "OpenSearchVpcEndpoint": {
            "Type": "AWS::OpenSearchServerless::VpcEndpoint",
            "Properties": {
                "Name": {
                    "Fn::Sub": "${ProjectPrefix}-vectors-vpce"
                },
                "VpcId": {
                    "Ref": "VpcId"
                },
                "SubnetIds": [
                    {
                        "Ref": "PrivateSubnetAId"
                    },
                    {
                        "Ref": "PrivateSubnetBId"
                    }
                ],
                "SecurityGroupIds": [
                    {
                        "Ref": "InternalSecurityGroupId"
                    }
                ]
            }
        },
        "VectorCollection": {
            "Type": "AWS::OpenSearchServerless::Collection",
            "DependsOn": [
                "DataAccessPolicy",
                "EncryptionPolicy",
                "NetworkPolicy"
            ],
            "Properties": {
                "Name": {
                    "Fn::Sub": "${ProjectPrefix}-vectors"
                },
                "Type": "VECTORSEARCH",
                "Description": "Vector search collection for RAG pipeline embeddings",
                "StandbyReplicas": {
                    "Ref": "StandbyReplicas"
                },
                "Tags": [
                    {
                        "Key": "Environment",
                        "Value": { "Ref": "EnvironmentTag" }
                    },
                    {
                        "Key": "Project",
                        "Value": "RAGPipeline"
                    }
                ]
            }
        }
    },
    "Outputs": {
        "CollectionArn": {
            "Description": "OpenSearch Serverless collection ARN",
            "Value": {
                "Fn::GetAtt": [
                    "VectorCollection",
                    "Arn"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-CollectionArn"
                }
            }
        },
        "CollectionEndpoint": {
            "Description": "OpenSearch Serverless collection endpoint",
            "Value": {
                "Fn::GetAtt": [
                    "VectorCollection",
                    "CollectionEndpoint"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-CollectionEndpoint"
                }
            }
        },
        "CollectionId": {
            "Description": "OpenSearch Serverless collection ID",
            "Value": {
                "Ref": "VectorCollection"
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-CollectionId"
                }
            }
        },
        "DashboardEndpoint": {
            "Description": "OpenSearch Dashboards endpoint",
            "Value": {
                "Fn::GetAtt": [
                    "VectorCollection",
                    "DashboardEndpoint"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-DashboardEndpoint"
                }
            }
        },
        "VpcEndpointId": {
            "Description": "OpenSearch Serverless VPC endpoint ID",
            "Value": {
                "Fn::GetAtt": [
                    "OpenSearchVpcEndpoint",
                    "Id"
                ]
            },
            "Export": {
                "Name": {
                    "Fn::Sub": "${AWS::StackName}-VpcEndpointId"
                }
            }
        }
    }
}
